<IfModule mod_rewrite.c>
  RewriteEngine On

  # Proxy API requests to the backend server
  RewriteRule ^api/(.*)$ https://api.atriengineers.com/public/api/$1 [P,L]

  # SPA fallback: redirect non-file, non-directory requests to index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
